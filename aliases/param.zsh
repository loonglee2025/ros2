#!/usr/bin/env zsh
# vim: set ft=zsh:
# =============================================================================
# aliases/param.zsh — ros2 param shortcuts
# Prefix: rp (ros2 param)
# =============================================================================

alias rpl='ros2 param list'                    # List params of a node
alias rpg='ros2 param get'                     # Get param value
alias rps='ros2 param set'                     # Set param value
alias rpd='ros2 param delete'                  # Delete param
alias rpdump='ros2 param dump'                 # Dump params to file
alias rpload='ros2 param load'                 # Load params from file
alias rpdesc='ros2 param describe'             # Describe param
